# Public values from the Supabase dashboard's Connect panel.
# These values are embedded in the application bundle and are not secrets.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_public_key

# Never add a service-role key, secret key or database password to an EXPO_PUBLIC_ variable.
